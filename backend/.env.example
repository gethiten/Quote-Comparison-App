# Database
DATABASE_URL=postgresql://quoteadmin:YourPassword@your-server.postgres.database.azure.com:5432/quote_comparison?sslmode=require

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=your_connection_string_here
AZURE_STORAGE_CONTAINER=quote-documents

# Azure OpenAI / Azure AI Foundry (token-based auth supported)
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Azure AI Content Understanding
AZURE_CONTENT_UNDERSTANDING_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_CONTENT_UNDERSTANDING_ANALYZER_ID=insuranceQuoteExtractor

# App Settings
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
