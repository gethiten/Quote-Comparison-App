      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.CognitiveServices/accounts/{0}', parameters('aiAccountName'))]",
      "name": "[guid(resourceId('Microsoft.CognitiveServices/accounts', parameters('aiAccountName')), parameters('functionAppName'), 'cognitive-services-user')]",
      "properties": {
        "roleDefinitionId": "[variables('cognitiveServicesUserRoleId')]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2023-12-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', parameters('aiAccountName'))]",
        "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]"
      ]
    },
    {
      "condition": "[parameters('enableBackendWebApp')]",
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[parameters('backendPlanName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": {
        "name": "[parameters('appServiceSkuName')]",
        "tier": "Basic",
        "size": "[parameters('appServiceSkuName')]",
        "capacity": 1
      },
      "tags": "[variables('tags')]",
      "properties": {
        "reserved": true
      }
    },
    {
      "condition": "[parameters('enableBackendWebApp')]",
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('backendWebAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "tags": "[variables('tags')]",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('backendPlanName'))]",
        "httpsOnly": true,
        "clientAffinityEnabled": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('backendPlanName'))]"
      ]
    },
    {
      "condition": "[parameters('enableBackendWebApp')]",
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', parameters('backendWebAppName'), 'web')]",
      "properties": {
        "linuxFxVersion": "PYTHON|3.12",
        "alwaysOn": true,
        "ftpsState": "Disabled",
        "minTlsVersion": "1.2",
        "appCommandLine": "gunicorn -k uvicorn.workers.UvicornWorker app.main:app --bind=0.0.0.0:$PORT"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('backendWebAppName'))]"
      ]
    },
    {
      "condition": "[parameters('enableBackendWebApp')]",
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', parameters('backendWebAppName'), 'appsettings')]",
      "properties": {
        "SCM_DO_BUILD_DURING_DEPLOYMENT": "true",
        "WEBSITE_RUN_FROM_PACKAGE": "0",
        "APP_ENV": "[parameters('environmentName')]",
        "CORS_ORIGINS": "http://localhost:5173,http://localhost:3000",
        "DATABASE_URL": "[variables('databaseUrl')]",
        "AZURE_STORAGE_CONTAINER": "[parameters('blobContainerName')]",
        "AZURE_OPENAI_ENDPOINT": "[variables('aiEndpoint')]",
        "AZURE_OPENAI_DEPLOYMENT": "[parameters('openAiDeploymentName')]",
        "AZURE_OPENAI_API_KEY": "",
        "AZURE_OPENAI_API_VERSION": "2025-01-01-preview",
        "AZURE_CONTENT_UNDERSTANDING_ENDPOINT": "[variables('aiEndpoint')]",
        "AZURE_CONTENT_UNDERSTANDING_ANALYZER_ID": "[parameters('contentUnderstandingAnalyzerId')]",
        "APPLICATIONINSIGHTS_CONNECTION_STRING": "[reference(resourceId('Microsoft.Insights/components', format('{0}-appi', parameters('backendWebAppName'))), '2020-02-02').ConnectionString]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', format('{0}-appi', parameters('backendWebAppName')))]",
        "[resourceId('Microsoft.Web/sites', parameters('backendWebAppName'))]"
      ]
    },
    {
      "condition": "[parameters('enableBackendWebApp')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.CognitiveServices/accounts/{0}', parameters('aiAccountName'))]",
      "name": "[guid(resourceId('Microsoft.CognitiveServices/accounts', parameters('aiAccountName')), parameters('backendWebAppName'), 'cognitive-services-user')]",
      "properties": {
        "roleDefinitionId": "[variables('cognitiveServicesUserRoleId')]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('backendWebAppName')), '2023-12-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', parameters('aiAccountName'))]",
        "[resourceId('Microsoft.Web/sites', parameters('backendWebAppName'))]"
      ]
    }
  ],
  "outputs": {
    "storageAccountResourceName": {
      "type": "string",
      "value": "[parameters('storageAccountName')]"
    },
    "quoteDocumentsContainer": {
      "type": "string",
      "value": "[parameters('blobContainerName')]"
    },
    "postgresServerFqdn": {
      "type": "string",
      "value": "[variables('postgresFqdn')]"
    },
    "postgresDatabase": {
      "type": "string",
      "value": "[parameters('postgresDatabaseName')]"
    },
    "aiServicesEndpoint": {
      "type": "string",
      "value": "[variables('aiEndpoint')]"
    },
    "aiFoundryProjectResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts/projects', parameters('aiAccountName'), parameters('foundryProjectName'))]"
    },
    "aiFoundryProjectApiUrl": {
      "type": "string",
      "value": "[format('https://{0}.services.ai.azure.com/api/projects/{1}', parameters('aiAccountName'), parameters('foundryProjectName'))]"
    },
    "contentUnderstandingAnalyzerName": {
      "type": "string",
      "value": "[parameters('contentUnderstandingAnalyzerId')]"
    },
    "communicationServiceNameOut": {
      "type": "string",
      "value": "[parameters('communicationServiceName')]"
    },
    "emailServiceNameOut": {
      "type": "string",
      "value": "[parameters('emailServiceName')]"
    },
    "emailSenderDomain": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Communication/emailServices/domains', parameters('emailServiceName'), parameters('emailDomainName')), '2023-06-01-preview').fromSenderDomain]"
    },
    "functionAppUrl": {
      "type": "string",
      "value": "[format('https://{0}.azurewebsites.net', parameters('functionAppName'))]"
    },
    "backendWebAppUrl": {
      "type": "string",
      "value": "[if(parameters('enableBackendWebApp'), format('https://{0}.azurewebsites.net', parameters('backendWebAppName')), '')]"
    },
    "storageBlobServiceUrl": {
      "type": "string",
      "value": "[variables('blobServiceUri')]"
    },
    "storageQueueServiceUrl": {
      "type": "string",
      "value": "[variables('queueServiceUri')]"
    }
  }
}